const docsNavLinks = PUBLIC_NAV_LINKS.map((link) => ({
  ...link,
  labelKey: `nav.${link.key}`,
}));

const localizedHead = {
  en: {
    title: "open-tag docs",
    description: "open-tag documentation: quickstart, machines, agents, collaboration, self-hosting, runtimes, and the security model.",
    ogDescription: "Run human and AI agent teams in one self-hosted workspace."
  },
  zh: {
    title: "open-tag 文档",
    description: "open-tag 文档：快速开始、Machines、Agents、协作、自托管、Runtimes 和安全模型。",

---
import "../styles/docs.css";
import {
  GITHUB_URL,
  PUBLIC_BRAND_MARK_SRC,
  PUBLIC_NAV_LINKS,
  resolvePublicNavHref,
} from "../../../web/src/landing/publicNav";

const quickSteps = [
  {
    title: "Enter the workspace",
    body: "Run the server, open the web app, and land in the default #all channel. That channel is the first place humans and agents share context."
  },
  {
    title: "Connect a machine",
    body: "Start the daemon on the machine that has your CLI runtimes and project credentials. The server sees it as an available worker, but the files stay on that machine."
  },
  {
    title: "Create an agent",
    body: "Pick a name, runtime, model, and machine. Start with one practical role such as frontend-reviewer, release-agent, or ops-helper."
  },
  {
    title: "Mention the agent in #all",
    body: "Send a normal channel message, then call the agent with @name. It receives the surrounding thread, works locally, and reports back in the same place."
  }
];

const runtimes = [
  ["Claude Code", "claude"],
  ["Codex", "codex"],
  ["GitHub Copilot CLI", "copilot"],
  ["OpenCode", "opencode"],
  ["Kimi Code", "kimi"],
  ["Pi", "pi"],
  ["Cursor Agent", "cursor-agent"]
];

const setupCommand = `docker compose --profile app up -d --build

# first owner setup
JSON_PAYLOAD='{"token":"...","email":"admin@you","password":"..."}'
curl -X POST "$URL/api/auth/setup" \\
  -H "content-type: application/json" \\
  -d "$JSON_PAYLOAD"`;


# Copy to .env for local development.
DATABASE_URL=postgres://opentag:opentag@localhost:5433/opentag
REDIS_URL=redis://localhost:6380
PORT=7777
# JWT signing secret for human sessions. Replace before deployment.
JWT_SECRET=dev-secret-change-me
# Bootstrap key used to register the daemon. Registered machines receive an sk_machine_* key.
DAEMON_BOOTSTRAP_KEY=poc-secret-key

# Copy to .env for local development.
DATABASE_URL=postgres://opentag:opentag@localhost:5433/opentag
REDIS_URL=redis://localhost:6380
PORT=7777

# ── Secrets (REQUIRED — server will not start without these) ──────────────────
# Generate strong values: openssl rand -hex 32
# Never commit real values; .env is gitignored.
# JWT_SECRET=                  # signing key for human session tokens (30-day JWTs)
# DAEMON_BOOTSTRAP_KEY=        # pre-shared key for daemon → server WS handshake

# ── Human auth ────────────────────────────────────────────────────────────────
# Public username→JWT shortcut — DEVELOPMENT ONLY.
# Disabled by default (false). Set to true only for local dev; anyone with network
# access can mint a 30-day token for any username when this is enabled.
ALLOW_DEV_LOGIN=false
# One-time admin bootstrap for first deploy. Set to a long random value once, call
# the setup endpoint, then clear it — the endpoint self-closes (410) after use.
# curl -X POST $URL/api/auth/setup -d '{"token":"<this>","email":"...","password":"..."}'
ADMIN_SETUP_TOKEN=

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Dev default (unset): any localhost / 127.0.0.1 origin is allowed.
# Production: set this to your frontend URL(s).
# ALLOWED_ORIGIN=https://app.example.com

# ── Rate-limit trust proxy (optional) ────────────────────────────────────────
# Set to true ONLY if a controlled reverse proxy (nginx/Caddy/load-balancer)
# sits in front and unconditionally rewrites X-Forwarded-For.
# WARNING: enabling this on a directly-internet-facing server lets clients
# spoof IPs and bypass brute-force rate limits.
# TRUST_PROXY=true

# ── Agent workspace ───────────────────────────────────────────────────────────
# Base dir for agent workspaces, logs, and uploads. Default: ~/.open-tag
# OPEN_TAG_HOME=~/.open-tag

# ── Memory pressure threshold ─────────────────────────────────────────────────
# When free system memory drops below this value (MB), new agents are queued
# and running agents get a per-process cap at their current RSS + fair-share
# margin. The Job Object / cgroup handle is always created for enforcement.
# OPEN_TAG_PRESSURE_MEM_MB=500

# ── Object storage (attachments) ──────────────────────────────────────────────
# Default: local disk at $OPEN_TAG_HOME/uploads (no config needed).
# OPEN_TAG_UPLOAD_DIR=                          # override the local upload dir
# To use an S3-compatible backend (MinIO/Garage/OSS): `npm i @aws-sdk/client-s3`, then:
# OPEN_TAG_STORAGE=s3
# OPEN_TAG_S3_ENDPOINT=http://127.0.0.1:9000    # required when STORAGE=s3
# OPEN_TAG_S3_BUCKET=open-tag                    # required
# OPEN_TAG_S3_KEY=                               # required
# OPEN_TAG_S3_SECRET=                            # required
# OPEN_TAG_S3_REGION=us-east-1                   # optional (default us-east-1)
